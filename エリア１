parsed_json as (
  SELECT jsonb_array_elements(json_content) as q
  FROM raw_json
)
INSERT INTO public.quizzes (stage, question, "choice 1", "choice 2", "choice 3", "choice 4", answer)
SELECT 
  CASE 
    WHEN (q->>'n')::int <= 35 THEN '1-1'
    WHEN (q->>'n')::int <= 55 THEN '1-2'
    ELSE '1-3'
  END as stage,
  q->>'b' as question,
  q->'o'->>0 as "choice 1",
  q->'o'->>1 as "choice 2",
  q->'o'->>2 as "choice 3",
  q->'o'->>3 as "choice 4",
  CASE q->>'a'
    WHEN 'ア' THEN 1
    WHEN 'イ' THEN 2
    WHEN 'ウ' THEN 3
    WHEN 'エ' THEN 4
    ELSE 1
  END as answer
FROM parsed_json;

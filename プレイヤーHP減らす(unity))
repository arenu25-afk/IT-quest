/// <summary>
/// クイズを間違えたとき、現在のHPからステージに応じたミスダメージを引いてSupabaseに保存する
/// </summary>
public IEnumerator TakeMissDamageCoroutine(int id)
{
    // 1. 同期されている現在のHPから、ステージごとのダメージ量（100 or 1000）を引き算する
    int nextHp = playerCurrentHp - playerMissDamage;
    
    // HPが0以下にならないように防衛
    if (nextHp < 0) nextHp = 0;

    // 2. Supabaseのデータを更新するためのURLとJSON
    string url = $"{supabaseUrl}/rest/v1/player?id=eq.{id}";
    string jsonPayload = "{\"current_hp\":" + nextHp + "}";
    byte[] bodyRaw = Encoding.UTF8.GetBytes(jsonPayload);

    using (UnityWebRequest request = new UnityWebRequest(url, "PATCH"))
    {
        request.uploadHandler = new UploadHandlerRaw(bodyRaw);
        request.downloadHandler = new DownloadHandlerBuffer();
        SetupHeaders(request);

        yield return request.SendWebRequest();

        if (request.result == UnityWebRequest.Result.Success)
        {
            // 3. Unity側の現在のHP変数も最新状態に上書き
            playerCurrentHp = nextHp;
            Debug.Log($"<color=red>×不正解！ {playerMissDamage} ダメージ受けて残りHP: {playerCurrentHp}</color>");
            
            if (playerCurrentHp <= 0)
            {
                Debug.Log("💀 プレイヤーのHPが0になりました。ゲームオーバー処理へ");
            }
        }
        else
        {
            Debug.LogError("HPの減算保存に失敗しました: " + request.error);
        }
    }
}

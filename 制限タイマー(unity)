using System.Collections;
using System.Text;
using UnityEngine;
using UnityEngine.UI; // 通常のText用
using TMPro;         // TextMeshPro用
using UnityEngine.Networking;

public class QuizTimer : MonoBehaviour
{
    [Header("Supabase設定（ダメージ受ける用）")]
    [SerializeField] private string supabaseUrl = "https://wfbstrbvfjzwrhyzxvfs.supabase.co";
    [SerializeField] private string anonKey = "ここにあなたのANON_KEYを貼り付けてください";
    public int playerId = 1;
    public int playerCurrentHp;   // 現在のHP（Unity側同期用）
    public int playerMissDamage;  // ステージごとのミスダメージ（100 or 1000）

    [Header("タイマー設定")]
    [SerializeField] private float timeLimit = 80f; // 1分20秒 = 80秒
    private float currentTimer;
    private bool isTimerRunning = false;

    [Header("タイマー表示用UI")]
    [SerializeField] private TMP_Text timerTextTMP;
    [SerializeField] private Text timerTextLegacy;

    void Start()
    {
        // テスト用：ゲーム開始と同時に最初の問題タイマーをスタートさせる場合
        StartNewQuestion();
    }

    void Update()
    {
        if (isTimerRunning)
        {
            currentTimer -= Time.deltaTime;
            UpdateTimerUI();

            // 0秒になったら時間切れ（不正解扱い）
            if (currentTimer <= 0)
            {
                currentTimer = 0;
                UpdateTimerUI();
                OnTimeUp();
            }
        }
    }

    /// <summary>
    /// 新しい問題を出題（タイマーを80秒にリセットして再始動）
    /// </summary>
    public void StartNewQuestion()
    {
        currentTimer = timeLimit;
        isTimerRunning = true;
        Debug.Log("⏰ 新しい問題：タイマースタート（制限時間 1分20秒）");
    }

    /// <summary>
    /// タイマーを「分:秒」に変換してUIに表示
    /// </summary>
    private void UpdateTimerUI()
    {
        int minutes = Mathf.FloorToInt(currentTimer / 60F);
        int seconds = Mathf.FloorToInt(currentTimer % 60F);
        string timeString = string.Format("{0:0}:{1:00}", minutes, seconds);

        if (timerTextTMP != null) timerTextTMP.text = timeString;
        if (timerTextLegacy != null) timerTextLegacy.text = timeString;
    }

    /// <summary>
    /// 【時間切れ処理】自動で不正解ダメージを処理し、次の問題へリセット
    /// </summary>
    private void OnTimeUp()
    {
        isTimerRunning = false; // 一旦タイマーを止める
        Debug.Log("<color=red>⏰ 時間切れ！不正解（1ミス）となりました。</color>");

        // ダメージを引いてSupabaseに保存し、その後自動で次の問題へ
        StartCoroutine(TakeMissDamageAndNextLoopCoroutine(playerId));
    }

    /// <summary>
    /// 不正解ダメージを保存し、自動でタイマーをリセットして次の問題へ行くコルーチン
    /// </summary>
    private IEnumerator TakeMissDamageAndNextLoopCoroutine(int id)
    {
        // 1. 同期されている現在のHPから、ステージごとのダメージ量（100 or 1000）を引く
        int nextHp = playerCurrentHp - playerMissDamage;
        if (nextHp < 0) nextHp = 0;

        string url = $"{supabaseUrl}/rest/v1/player?id=eq.{id}";
        string jsonPayload = "{\"current_hp\":" + nextHp + "}";
        byte[] bodyRaw = Encoding.UTF8.GetBytes(jsonPayload);

        using (UnityWebRequest request = new UnityWebRequest(url, "PATCH"))
        {
            request.uploadHandler = new UploadHandlerRaw(bodyRaw);
            request.downloadHandler = new DownloadHandlerBuffer();
            SetupHeaders(request);

            yield return request.SendWebRequest();

            if (request.result == UnityWebRequest.Result.Success)
            {
                playerCurrentHp = nextHp;
                Debug.Log($"<color=red>×ダメージ適用！ 残りHP: {playerCurrentHp}</color>");

                if (playerCurrentHp <= 0)
                {
                    Debug.Log("💀 プレイヤーのHPが0になりました（ゲームオーバー）");
                    // ここにゲームオーバー画面への遷移などを書けます
                }
                else
                {
                    // まだHPがあるなら、1秒だけ「時間切れ！」の余韻を作ってから次の問題へ自動リセット
                    yield return new WaitForSeconds(1.0f);
                    
                    // 【時間をリセットして次の問題へ！】
                    StartNewQuestion();
                }
            }
            else
            {
                Debug.LogError("HPの保存に失敗しました: " + request.error);
            }
        }
    }

    private void SetupHeaders(UnityWebRequest request)
    {
        request.SetRequestHeader("Content-Type", "application/json");
        request.SetRequestHeader("apikey", anonKey);
        request.SetRequestHeader("Authorization", "Bearer " + anonKey);
    }
}
